{
  "$ref": "#/definitions/Config",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "AIVendor": {
      "anyOf": [
        {
          "$ref": "#/definitions/OpenAIVendor"
        },
        {
          "additionalProperties": false,
          "properties": {
            "apiEndpointEnvName": {
              "description": "Azure OpenAIのエンドポイントを格納するKeychainのアカウント名",
              "type": "string"
            },
            "apiKeyEnvName": {
              "description": "Azure OpenAIのApiKeyを格納するKeychainのアカウント名",
              "type": "string"
            },
            "apiModel": {
              "description": "Azure OpenAIのモデル名",
              "type": "string"
            },
            "apiVersion": {
              "description": "Azure OpenAIのAPIバージョン",
              "type": "string"
            },
            "type": {
              "const": "azure",
              "type": "string"
            }
          },
          "required": [
            "type",
            "apiKeyEnvName",
            "apiEndpointEnvName",
            "apiVersion",
            "apiModel"
          ],
          "type": "object"
        }
      ]
    },
    "Config": {
      "additionalProperties": false,
      "description": "Carnelianプラグインの設定ファイルを定義するインターフェース JSON Schemaを生成するためにも使用される\n\nINFO: ここではrequiredになっていても、設定ミスでnullishな値は入る可能性があるので、処理するときは例外処理が必要\n\n## 依存関係\n- ImageMagick: 画像変換コマンド用（Homebrew経由でインストール）\n- OpenAI API: AI機能用（設定でAPIキーが必要）\n- インターネット接続: OGPメタデータ取得用\n- Bluesky API: ソーシャルメディア統合用\n\n## モバイル互換性 一部コマンドはiOS/Androidで動作しない可能性があります",
      "properties": {
        "all": {
          "additionalProperties": false,
          "description": "グローバルコマンド（ファイルを開いていなくても実行可能）",
          "properties": {
            "Clean old daily notes": {
              "description": "14日前より古いデイリーノートを別ディレクトリに移動（要Obsidian再起動でキャッシュ更新）",
              "type": "boolean"
            },
            "Copy daily note section in range": {
              "additionalProperties": false,
              "description": "指定期間のDaily Noteから特定セクションを集約してクリップボードにコピー",
              "properties": {
                "sectionLevel": {
                  "description": "対象セクションのレベル",
                  "type": "number"
                },
                "sectionName": {
                  "description": "対象セクション名",
                  "type": "string"
                }
              },
              "required": [
                "sectionName",
                "sectionLevel"
              ],
              "type": "object"
            },
            "Create MIN ADR": {
              "description": "Minerva用ADRを作成。自動採番とADRリスト更新",
              "type": "boolean"
            },
            "Create OBS ADR": {
              "description": "Obsidian用ADRを作成",
              "type": "boolean"
            },
            "Create PRO ADR": {
              "description": "PRO用ADRを作成",
              "type": "boolean"
            },
            "Create VIM ADR": {
              "description": "Vim用ADRを作成。経緯・提案内容・メリット/デメリットのセクション付き",
              "type": "boolean"
            },
            "Create an Article": {
              "description": "📘 Articlesディレクトリに記事を作成。カバー画像とプロパティを自動設定",
              "type": "boolean"
            },
            "Create new note horizontally": {
              "description": "水平方向に新しいノートを作成",
              "type": "boolean"
            },
            "Create new note vertically": {
              "description": "垂直方向に新しいノートを作成",
              "type": "boolean"
            },
            "Move to next workspace": {
              "description": "次のワークスペースに移動",
              "type": "boolean"
            },
            "Open active file in yazi": {
              "description": "現在のVaultをyaziで開く（yazi, Ghostty, zsh必須）",
              "type": "boolean"
            },
            "Open active folder in terminal": {
              "description": "現在のディレクトリをターミナルで開く（Ghostty必須）",
              "type": "boolean"
            },
            "Open vault in lazygit": {
              "description": "現在のVaultをLazygitで開く（Ghostty必須）",
              "type": "boolean"
            },
            "Open vault in terminal": {
              "description": "現在のVaultをターミナルで開く（Ghostty必須）",
              "type": "boolean"
            },
            "Publish": {
              "additionalProperties": false,
              "description": "前処理を行いObsidian Publishに公開する",
              "properties": {
                "changelogNotePath": {
                  "description": "更新履歴のノートパス (ex: 更新履歴.md)",
                  "type": "string"
                },
                "ignoreFiles": {
                  "description": "更新ファイルに含めないファイルパスのglobパターン配列 default: [] ex: [\"Templates/**\", \"Notes/Untitled.md\"]",
                  "items": {
                    "type": "string"
                  },
                  "type": "array"
                }
              },
              "type": "object"
            },
            "Toggle Live preview": {
              "description": "ライブプレビュー/ソースモード切替。全エディタが対象",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "click": {
          "additionalProperties": false,
          "description": "クリックイベントに関連するコマンド",
          "properties": {
            "Open link vertically": {
              "description": "修飾キーを押しながら左クリックしたときに垂直分割で開くサービス",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "editor": {
          "additionalProperties": false,
          "description": "エディタコンテキストで実行可能なコマンド",
          "properties": {
            "Add permalink property": {
              "additionalProperties": false,
              "description": "パーマリンクプロパティを追加（Articleはタイトルから生成、それ以外はADRとして）",
              "properties": {
                "vendor": {
                  "anyOf": [
                    {
                      "additionalProperties": false,
                      "properties": {
                        "apiKeyEnvName": {
                          "description": "OpenAI APIキーを格納するKeychainのアカウント名",
                          "type": "string"
                        },
                        "type": {
                          "const": "openai",
                          "type": "string"
                        }
                      },
                      "required": [
                        "apiKeyEnvName",
                        "type"
                      ],
                      "type": "object"
                    },
                    {
                      "additionalProperties": false,
                      "properties": {
                        "apiEndpointEnvName": {
                          "description": "Azure OpenAIのエンドポイントを格納するKeychainのアカウント名",
                          "type": "string"
                        },
                        "apiKeyEnvName": {
                          "description": "Azure OpenAIのApiKeyを格納するKeychainのアカウント名",
                          "type": "string"
                        },
                        "apiModel": {
                          "description": "Azure OpenAIのモデル名",
                          "type": "string"
                        },
                        "apiVersion": {
                          "description": "Azure OpenAIのAPIバージョン",
                          "type": "string"
                        },
                        "type": {
                          "enum": [],
                          "type": "string"
                        }
                      },
                      "required": [
                        "apiEndpointEnvName",
                        "apiKeyEnvName",
                        "apiModel",
                        "apiVersion",
                        "type"
                      ],
                      "type": "object"
                    }
                  ],
                  "description": "利用するAIベンダー情報"
                }
              },
              "required": [
                "vendor"
              ],
              "type": "object"
            },
            "Add property suitably": {
              "description": "カーソル行の内容からよしなにプロパティを追加（URL→url、その他→description）",
              "type": "boolean"
            },
            "Clear task status": {
              "description": "タスクのチェック状態とタイマー表記をクリア",
              "type": "boolean"
            },
            "Copy Minerva URL": {
              "description": "現在ファイルのObsidian Publish URLを生成してコピー",
              "type": "boolean"
            },
            "Copy Strip links and decorations": {
              "description": "選択テキストからリンクや装飾を除去してコピー（モバイル非対応）",
              "type": "boolean"
            },
            "Copy as Confluence": {
              "additionalProperties": false,
              "description": "現在の内容をConfluence記法に変換してコピー",
              "properties": {
                "domain": {
                  "description": "Confluenceのドメイン 例: `example.atlassian.net`",
                  "type": "string"
                }
              },
              "required": [
                "domain"
              ],
              "type": "object"
            },
            "Copy as Slack": {
              "additionalProperties": false,
              "description": "現在の内容をSlack記法に変換してコピー",
              "properties": {
                "replaceRegExpMapping": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "description": "Slackのメッセージを置換するための正規表現マッピング",
                  "type": "object"
                }
              },
              "type": "object"
            },
            "Copy url property": {
              "description": "現在ファイルのurlプロパティ値をコピー",
              "type": "boolean"
            },
            "Create Activity note": {
              "description": "📜 Activity noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create Brain note": {
              "description": "🧠 Brain noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create Hub note": {
              "description": "📒 Hub noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create MTG note": {
              "description": "📅 MTG用ノートを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create Obsidian逆引きレシピ": {
              "description": "📗 Obsidian逆引きレシピを作成",
              "type": "boolean"
            },
            "Create Prime note": {
              "description": "📕 Prime noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create Report note": {
              "description": "📰 Report noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create TDQ": {
              "description": "TDQを作成し、カーソル位置にリンク挿入（自動採番）",
              "type": "boolean"
            },
            "Create Trouble Shooting note": {
              "description": "📝 Troubleshooting noteを作成し、カーソル位置にリンク挿入",
              "type": "boolean"
            },
            "Create task note": {
              "additionalProperties": false,
              "description": "📌 タスクノートを作成し、カーソル位置にリンク挿入",
              "properties": {
                "directory": {
                  "description": "タスクノートの保存先ディレクトリ",
                  "type": "string"
                }
              },
              "required": [
                "directory"
              ],
              "type": "object"
            },
            "Cycle bullet/checkbox": {
              "description": "箇条書き/チェックボックスを切り替え",
              "type": "boolean"
            },
            "Duplicate line down": {
              "description": "現在行を下方向に複製",
              "type": "boolean"
            },
            "Duplicate line up": {
              "description": "現在行を上方向に複製",
              "type": "boolean"
            },
            "Fix link": {
              "description": "[[title (alias)]]を[[title (alias)|title]]形式に修正",
              "type": "boolean"
            },
            "Focus editor content": {
              "description": "エディタの本文にフォーカスを移す",
              "type": "boolean"
            },
            "Format table": {
              "description": "Markdownテーブルを整形（モバイル非対応）",
              "type": "boolean"
            },
            "Insert Bluesky posts to weekly note": {
              "description": "指定週のBlueskyポストをカード形式で挿入（外部URL付きのみ）",
              "type": "boolean"
            },
            "Insert Done to Weekly Report": {
              "description": "週の期間内のDaily Notesから『やったこと』をトップレベル項目ごとにマージして挿入",
              "type": "boolean"
            },
            "Insert MOC": {
              "description": "MOCテンプレートを挿入",
              "type": "boolean"
            },
            "Insert new notes to the weekly note": {
              "description": "週の期間内に作成されたパブリックノートのリストを挿入",
              "type": "boolean"
            },
            "Insert note card": {
              "description": "内部ノート用のカードレイアウトを作成（ファイルピッカー）",
              "type": "boolean"
            },
            "Move to next inspection": {
              "description": "現在ファイルの次のリンティング問題に移動",
              "type": "boolean"
            },
            "Move to previous inspection": {
              "description": "現在ファイルの前のリンティング問題に移動",
              "type": "boolean"
            },
            "Open as local MkDocs site": {
              "additionalProperties": false,
              "description": "ローカルMkDocsサイトとして開く",
              "properties": {
                "baseUrl": {
                  "description": "ex: http://localhost:8081 (default: http://localhost:8000)",
                  "type": "string"
                },
                "docsRootPath": {
                  "description": "ex: notes (default: docs)",
                  "type": "string"
                }
              },
              "type": "object"
            },
            "Open as remote MkDocs site": {
              "additionalProperties": false,
              "description": "リモートMkDocsサイトとして開く",
              "properties": {
                "baseUrl": {
                  "description": "ex: http://your-mkdocs-domain",
                  "type": "string"
                },
                "docsRootPath": {
                  "description": "ex: notes (default: docs)",
                  "type": "string"
                }
              },
              "required": [
                "baseUrl"
              ],
              "type": "object"
            },
            "Open property URL": {
              "description": "ファイルのurlプロパティに保存されたURLを開く",
              "type": "boolean"
            },
            "Paste Bluesky embed": {
              "description": "クリップボードのBluesky埋め込みスクリプトから埋め込みHTMLを挿入",
              "type": "boolean"
            },
            "Paste URL to site link": {
              "description": "クリップボードURLからOGPメタデータを取得してMarkdownリンク挿入",
              "type": "boolean"
            },
            "Paste clipboard as AVIF": {
              "additionalProperties": false,
              "description": "クリップボード画像をAVIF変換して保存・挿入（ImageMagick必須）",
              "properties": {
                "maxWidth": {
                  "description": "最大幅 (超えている場合は自動で縮小する)",
                  "type": "number"
                },
                "quality": {
                  "description": "AVIFの品質 (default: 35)",
                  "type": "number"
                }
              },
              "type": "object"
            },
            "Paste clipboard as WebP": {
              "additionalProperties": false,
              "description": "クリップボード画像をWebP変換して保存・挿入（ImageMagick必須）",
              "properties": {
                "maxWidth": {
                  "description": "最大幅 (超えている場合は自動で縮小する)",
                  "type": "number"
                }
              },
              "type": "object"
            },
            "Paste clipboard as WebP for OGP": {
              "description": "クリップボード画像をOGPに最適なサイズでWebP変換して保存・挿入（ImageMagick必須）",
              "type": "boolean"
            },
            "Paste site card": {
              "description": "クリップボードURLからOGPメタデータを取得してサイトカード挿入",
              "type": "boolean"
            },
            "Save with": {
              "description": "LintやFormatなどを実行して保存",
              "type": "boolean"
            },
            "Strip links and decorations": {
              "description": "選択範囲のリンクや装飾を無効化（1文字リンク非対応、モバイル非対応）",
              "type": "boolean"
            },
            "Summarize description": {
              "additionalProperties": false,
              "description": "OpenAI APIで150文字の説明を生成しdescriptionプロパティに設定",
              "properties": {
                "property": {
                  "description": "要約を保存するプロパティ名 (default: description)",
                  "type": "string"
                },
                "vendor": {
                  "$ref": "#/definitions/AIVendor",
                  "description": "利用するAIベンダー情報"
                }
              },
              "required": [
                "vendor"
              ],
              "type": "object"
            },
            "Transform MOC": {
              "description": "MOCを新しい形式に変換",
              "type": "boolean"
            },
            "Transform to v2 OGP card": {
              "description": "カーソル配下のOGPカードをv2形式に変換（情報も最新化）",
              "type": "boolean"
            },
            "Update MOC suitably": {
              "description": "MOCがなければ挿入、あれば新形式に変換",
              "type": "boolean"
            },
            "Update change log": {
              "description": "created/updatedプロパティを更新（HTMLフッターがあればその日付を使用）",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "file": {
          "additionalProperties": false,
          "description": "ファイルを開いているときに実行可能なコマンド",
          "properties": {
            "Copy active file full path": {
              "description": "現在のファイルのフルシステムパスをクリップボードにコピー",
              "type": "boolean"
            },
            "Copy active image file to clipboard": {
              "description": "現在の画像ファイルをクリップボードにコピー",
              "type": "boolean"
            },
            "Delete active file": {
              "description": "現在のファイルを削除（バックリンクが存在する場合はエラー）",
              "type": "boolean"
            },
            "Duplicate active file": {
              "description": "現在のファイルを複製して新しいタブで開く",
              "type": "boolean"
            },
            "Duplicate active file horizontally": {
              "description": "現在のファイルを複製して下方向に開く",
              "type": "boolean"
            },
            "Duplicate active file vertically": {
              "description": "現在のファイルを複製して右方向に開く",
              "type": "boolean"
            },
            "Show File info": {
              "description": "現在のファイルの詳細情報を表示",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "formatter": {
          "additionalProperties": false,
          "description": "保存時のフォーマッター設定",
          "properties": {
            "ignoreFiles": {
              "description": "変換を無視するファイルパスのglobパターン配列 default: [] ex: [\"Templates/**\", \"Notes/Untitled.md\"]",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "propertyOrder": {
              "description": "プロパティの並び順を指定する配列 (default: [\"title\", \"created\", \"updated\"])",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "removeIfEmpty": {
              "description": "空のプロパティを削除するかどうか (default: true)",
              "type": "boolean"
            }
          },
          "type": "object"
        },
        "linter": {
          "additionalProperties": false,
          "description": "リンター設定",
          "properties": {
            "rules": {
              "additionalProperties": false,
              "properties": {
                "content": {
                  "additionalProperties": false,
                  "description": "コンテンツに関するルール",
                  "properties": {
                    "Disallow fixme": {
                      "description": "本文のFIXME記述を禁止する",
                      "type": "boolean"
                    },
                    "Disallowed link card": {
                      "description": "リンクカードの利用を禁止しているノート種別で検出する",
                      "type": "boolean"
                    },
                    "Link ends with parenthesis": {
                      "description": "末尾に括弧を含む内部リンクを検出する（必要に応じ箇条書きを除外）",
                      "type": "boolean"
                    },
                    "No link comment": {
                      "description": "リンクカードに対応するリンクコメントの欠如を検出する",
                      "type": "boolean"
                    },
                    "Unofficial MOC format": {
                      "description": "最新仕様に従っていないMOCセクションを検出する",
                      "type": "boolean"
                    },
                    "Unresolved internal link": {
                      "description": "未解決の内部リンクを検出する",
                      "type": "boolean"
                    },
                    "v1 dates format": {
                      "description": "旧形式の投稿日/更新日ブロックを検出し、created/updatedを付与する",
                      "type": "boolean"
                    },
                    "v1 link card": {
                      "description": "旧形式(v1)のリンクカード使用を警告する",
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                },
                "propery": {
                  "additionalProperties": false,
                  "description": "プロパティに関するルール",
                  "properties": {
                    "Inconsistent description": {
                      "additionalProperties": false,
                      "description": "descriptionプロパティと本文の内容を比較し、不一致を検出する",
                      "properties": {
                        "ignoreFiles": {
                          "items": {
                            "type": "string"
                          },
                          "type": "array"
                        }
                      },
                      "type": "object"
                    },
                    "Inconsistent fixme": {
                      "description": "本文の!FIXMEや==強調とfixmeプロパティの状態を同期させる",
                      "type": "boolean"
                    },
                    "MkDocs title": {
                      "description": "MkDocs向けのtitleプロパティをファイル名と同期させる",
                      "type": "boolean"
                    },
                    "No cover": {
                      "description": "ノート種別に応じてcoverを自動付与・必須チェックする",
                      "type": "boolean"
                    },
                    "No description": {
                      "description": "descriptionプロパティが必須のノートで未設定を検出する",
                      "type": "boolean"
                    },
                    "No status": {
                      "description": "statusの未設定を検出し、必要に応じて既定値を割り当てる",
                      "type": "boolean"
                    },
                    "No url": {
                      "description": "urlプロパティが必要なノートで未設定を検出する",
                      "type": "boolean"
                    },
                    "Tags": {
                      "description": "タイトルやパスに応じて所定のタグ付与/削除を行う",
                      "type": "boolean"
                    }
                  },
                  "type": "object"
                }
              },
              "type": "object"
            }
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "OpenAIVendor": {
      "additionalProperties": false,
      "properties": {
        "apiKeyEnvName": {
          "description": "OpenAI APIキーを格納するKeychainのアカウント名",
          "type": "string"
        },
        "type": {
          "const": "openai",
          "type": "string"
        }
      },
      "required": [
        "type",
        "apiKeyEnvName"
      ],
      "type": "object"
    }
  }
}

